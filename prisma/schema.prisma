generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Simulation {
  id          String      @id @default(uuid())
  title       String
  slug        String      @unique
  description String?
  difficulty  String
  duration    Int?        // duration in minutes
  tags        String[]    @default([])
  instructions String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  questions   SimulationQuestion[]
  attempts    SimulationAttempt[]
}

model SimulationQuestion {
  id            String   @id @default(uuid())
  simulation    Simulation @relation(fields: [simulationId], references: [id])
  simulationId  String
  question      String
  correctDebit  String
  correctCredit String
  correctAmount Decimal
}

model SimulationAttempt {
  id           String   @id @default(uuid())
  userId       String
  simulation   Simulation @relation(fields: [simulationId], references: [id])
  simulationId String
  score        Int
  completed    Boolean  @default(false)
  startedAt    DateTime @default(now())
  completedAt  DateTime?
  timeSpent    Int?     // seconds
  progress     Json?
  answers      AttemptAnswer[]
  createdAt    DateTime @default(now())
}

model AttemptAnswer {
  id          String @id @default(uuid())
  attempt     SimulationAttempt @relation(fields: [attemptId], references: [id])
  attemptId   String
  questionId  String
  userDebit   String
  userCredit  String
  amount      Decimal
  correct     Boolean
  score       Int
}
